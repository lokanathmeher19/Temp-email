# ==========================================
# SYSTEM CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ==========================================
# DATABASE & REDIS
# ==========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://tempadmin:temppassword@localhost:5432/temp_email_db?schema=public"
REDIS_URL="redis://localhost:6379"

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_ACCESS_SECRET="generate_a_secure_random_string_here_for_access"
JWT_REFRESH_SECRET="generate_a_secure_random_string_here_for_refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ==========================================
# EMAIL SYSTEM (SMTP / MailHog)
# ==========================================
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""

# Primary domains for generated emails (comma separated)
SUPPORTED_DOMAINS="tempmail.local,disposable.local"

# ==========================================
# SMS PROVIDERS API KEYS
# ==========================================
TWILIO_ACCOUNT_SID="your_twilio_sid"
TWILIO_AUTH_TOKEN="your_twilio_token"
SMSPOOL_API_KEY="your_smspool_key"

# ==========================================
# PAYMENTS (Stripe)
# ==========================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==========================================
# STORAGE (AWS S3)
# ==========================================
AWS_ACCESS_KEY_ID="your_aws_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="temp-email-attachments"
