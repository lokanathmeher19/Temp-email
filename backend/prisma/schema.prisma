generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  PREMIUM
  ADMIN
}

enum MailboxStatus {
  ACTIVE
  EXPIRED
  DELETED
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  googleId      String?   @unique
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  mailboxes     Mailbox[]
  phoneNumbers  PhoneNumber[]
  apiKeys       APIKey[]
  subscriptions Subscription[]
}

model Mailbox {
  id          String        @id @default(uuid())
  address     String        @unique
  userId      String?       // Can be null for anonymous users
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  status      MailboxStatus @default(ACTIVE)
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  emails      Email[]
}

model Email {
  id            String       @id @default(uuid())
  mailboxId     String
  mailbox       Mailbox      @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  fromAddress   String
  fromName      String?
  subject       String?
  bodyText      String?
  bodyHtml      String?
  receivedAt    DateTime     @default(now())
  isRead        Boolean      @default(false)
  rawSource     String?      // Reference to raw MIME stored somewhere (S3) or string

  attachments   Attachment[]
}

model Attachment {
  id          String   @id @default(uuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  contentType String
  size        Int
  url         String   // S3 URL
  createdAt   DateTime @default(now())
}

model PhoneNumber {
  id          String       @id @default(uuid())
  number      String       @unique
  country     String
  provider    String       // Twilio, SMSPool, etc.
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  status      String       @default("ACTIVE") // ACTIVE, EXPIRED
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  messages    SMSMessage[]
}

model SMSMessage {
  id            String      @id @default(uuid())
  phoneNumberId String
  phoneNumber   PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  sender        String
  content       String
  receivedAt    DateTime    @default(now())
  isRead        Boolean     @default(false)
}

model APIKey {
  id          String   @id @default(uuid())
  key         String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
}

model Subscription {
  id                   String           @id @default(uuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?
  stripeSubscriptionId String?          @unique
  plan                 SubscriptionPlan @default(FREE)
  status               String           @default("active") // active, past_due, canceled
  currentPeriodEnd     DateTime
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  level     String   // info, warn, error
  message   String
  meta      Json?
  createdAt DateTime @default(now())
}
